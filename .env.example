# Copy to .env and fill in your keys. .env is gitignored.

# --- Fish Audio ---
FISH_API_KEY=your_fish_audio_api_key
# TTS model header. Fish Audio S2.1 Pro (free API tier).
FISH_MODEL=s2.1-pro-free
# 默认音色 reference_id：角色未单独绑定音色时使用
FISH_DEFAULT_VOICE_ID=

# --- Claude (via apiyi proxy) ---
CLAUDE_API_KEY=your_apiyi_key
CLAUDE_BASE_URL=https://api.apiyi.com
# 写稿默认模型（可在节目里逐期切换 claude-sonnet-4-6 / claude-opus-4-8）
CLAUDE_MODEL=claude-sonnet-4-6

# --- Gemini（联网搜索 / Deep Research，Google 官方 API）---
# Google Search、Deep Research、Deep Research Max 共用此 key
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# 估算语速：字数/分钟。稿子太短就调高（让模型多写），太长就调低。默认 300。
WORDS_PER_MINUTE=300

# Local server port
PORT=8787
